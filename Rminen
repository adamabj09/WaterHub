local H = game:GetService("HttpService")
local P = game.Players.LocalPlayer
local pG = P:WaitForChild("PlayerGui")

-- TU URL DE GOOGLE (Verificada por ti)
local url = "https://script.google.com/macros/s/AKfycbwFidcaEC0E2L72kUuyTyDqkx8PDpVoISwB5KBcO-t2pOmlLtQueCkFeYgVUFpdU96psg/exec"

-- FUNCIÓN DE VERIFICACIÓN
local function verificar(k)
    local req = (request or http_request or (syn and syn.request))
    if not req then return false end
    
    local success, response = pcall(function()
        return req({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = H:JSONEncode({key = k})
        })
    end)

    if success and response and response.StatusCode == 200 then
        local ok, result = pcall(function() return H:JSONDecode(response.Body) end)
        return ok and result and result.success
    end
    return false
end

-- --- FUNCIÓN DEL MENÚ DE CHEATS (Se abre tras la Key) ---
local function AbrirMenuPrincipal()
    local mainSg = Instance.new("ScreenGui", pG)
    mainSg.Name = "WaterHubMain"
    
    local frame = Instance.new("Frame", mainSg)
    frame.Size = UDim2.new(0, 200, 0, 250)
    frame.Position = UDim2.new(0.1, 0, 0.4, 0)
    frame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    frame.Active = true
    frame.Draggable = true
    Instance.new("UICorner", frame)

    local t = Instance.new("TextLabel", frame)
    t.Size = UDim2.new(1, 0, 0, 40)
    t.Text = "WATER HUB"
    t.TextColor3 = Color3.new(1,1,1)
    t.Font = Enum.Font.GothamBold
    t.BackgroundTransparency = 1

    local function createButton(name, pos, callback)
        local b = Instance.new("TextButton", frame)
        b.Size = UDim2.new(0, 160, 0, 35)
        b.Position = pos
        b.Text = name
        b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        b.TextColor3 = Color3.new(1, 1, 1)
        Instance.new("UICorner", b)
        b.MouseButton1Click:Connect(callback)
    end

    -- BOTÓN VELOCIDAD
    createButton("Velocidad (100)", UDim2.new(0.5, -80, 0.2, 0), function()
        P.Character.Humanoid.WalkSpeed = 100
    end)

    -- BOTÓN SALTO
    createButton("Salto (100)", UDim2.new(0.5, -80, 0.4, 0), function()
        P.Character.Humanoid.JumpPower = 100
    end)

    -- BOTÓN VOLAR (FLY)
    local flying = false
    createButton("Volar: OFF", UDim2.new(0.5, -80, 0.6, 0), function(btn)
        flying = not flying
        local btnObj = frame:FindFirstChild("Volar: OFF") or frame:FindFirstChild("Volar: ON")
        if flying then
            btnObj.Text = "Volar: ON"
            local bv = Instance.new("BodyVelocity", P.Character.HumanoidRootPart)
            bv.Velocity = Vector3.new(0,0,0)
            bv.MaxForce = Vector3.new(4500, 4500, 4500)
            bv.Name = "WaterFly"
            spawn(function()
                while flying do
                    bv.Velocity = game.Workspace.CurrentCamera.CFrame.LookVector * 100
                    wait()
                end
                bv:Destroy()
            end)
        else
            btnObj.Text = "Volar: OFF"
        end
    end)
end

-- --- INTERFAZ DE LOGIN ---
local sg = Instance.new("ScreenGui", pG)
sg.Name = "WaterHubLogin"

local loginF = Instance.new("Frame", sg)
loginF.Size = UDim2.new(0, 260, 0, 160)
loginF.Position = UDim2.new(0.5, -130, 0.4, -80)
loginF.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Instance.new("UICorner", loginF)

local input = Instance.new("TextBox", loginF)
input.Size = UDim2.new(0, 200, 0, 35)
input.Position = UDim2.new(0.5, -100, 0.35, 0)
input.PlaceholderText = "Escribe tu Key..."
input.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
input.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", input)

local btn = Instance.new("TextButton", loginF)
btn.Size = UDim2.new(0, 140, 0, 35)
btn.Position = UDim2.new(0.5, -70, 0.7, 0)
btn.Text = "ACTIVAR"
btn.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
btn.TextColor3 = Color3.new(1,1,1)
Instance.new("UICorner", btn)

btn.MouseButton1Click:Connect(function()
    local key = input.Text:gsub("%s+", ""):upper()
    if key == "" then return end
    
    btn.Text = "CONECTANDO..."
    if verificar(key) then
        btn.Text = "¡BIENVENIDO!"
        wait(1)
        sg:Destroy()
        AbrirMenuPrincipal()
    else
        btn.Text = "KEY INCORRECTA"
        wait(2)
        btn.Text = "ACTIVAR"
    end
end)
