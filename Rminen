local H = game:GetService("HttpService")
local url = "https://script.google.com/macros/s/AKfycbxU6FuiQoX02Ma-c6OcO43sehBe5yDW_sRwz6tI2kjGgjB9ocMihjhVzZM-JWFSb1rf2g/exec"

-- Función de Verificación
local function verificar(k)
    local req = request or http_request or (syn and syn.request) or (http and http.request)
    if not req then return false end
    
    local success, response = pcall(function()
        return req({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = H:JSONEncode({key = k})
        })
    end)
    
    if success and response and response.StatusCode == 200 then
        local ok, result = pcall(function() return H:JSONDecode(response.Body) end)
        if ok and result and result.success then
            return true
        end
    end
    return false
end

